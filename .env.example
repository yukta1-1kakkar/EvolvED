# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Managed databases
# Use a direct Neon endpoint for migrations (no -pooler hostname).
# Neon format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
DATABASE_URL=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_API_KEY=

# Model routing
ACTIVE_PROVIDER=bedrock
LEARNER_MODEL=anthropic.claude-sonnet-4-6
PEDAGOGY_MODEL=anthropic.claude-sonnet-4-6
LESSON_PLANNING_MODEL=anthropic.claude-sonnet-4-6
CONTENT_GENERATION_MODEL=anthropic.claude-sonnet-4-6
QUIZ_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
ASSESSMENT_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
ADAPTATION_MODEL=anthropic.claude-sonnet-4-6
EVOLUTION_MODEL=anthropic.claude-sonnet-4-6
FAST_INTERACTION_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_CONNECT_TIMEOUT_SECONDS=10
BEDROCK_READ_TIMEOUT_SECONDS=120
BEDROCK_MAX_ATTEMPTS=4
BEDROCK_RETRY_BASE_DELAY_SECONDS=0.5
TITAN_EMBEDDING_DIMENSIONS=1024
TITAN_EMBEDDING_NORMALIZE=true
POLLY_ENGINE=neural

# App
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
