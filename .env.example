# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Managed databases
# Use a direct Neon endpoint for migrations (no -pooler hostname).
# Neon format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
DATABASE_URL=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_API_KEY=

# Model routing
PEDAGOGY_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
LESSON_PLANNING_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
CONTENT_GENERATION_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
FAST_INTERACTION_MODEL=anthropic.claude-3-haiku-20240307-v1:0
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=4096
TITAN_EMBEDDING_DIMENSIONS=1024
TITAN_EMBEDDING_NORMALIZE=true
POLLY_ENGINE=neural

# App
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
